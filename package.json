{
  "name": "ferro",
  "version": "0.1.0",
  "description": "Ferro — a modern, security-focused FTP/FTPS/SFTP desktop client",
  "author": "Fahrettin Aksoy <backend@cyh.com.tr>",
  "license": "MIT",
  "homepage": "https://github.com/fahrettinaksoy/ferro#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fahrettinaksoy/ferro.git"
  },
  "bugs": {
    "url": "https://github.com/fahrettinaksoy/ferro/issues"
  },
  "keywords": [
    "ftp",
    "ftps",
    "sftp",
    "ftp-client",
    "file-transfer",
    "tauri",
    "vue",
    "desktop"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "build:vite": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run typecheck && tauri build",
    "tauri:build:mac": "tauri build --bundles dmg",
    "tauri:build:win": "tauri build --bundles nsis",
    "tauri:build:linux": "tauri build --bundles appimage,deb",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "test": "vitest run -c vitest.config.component.ts",
    "test:component": "vitest run -c vitest.config.component.ts",
    "test:watch": "vitest -c vitest.config.component.ts",
    "lint": "eslint . --cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mjs,cjs,vue}": "eslint --cache --fix",
    "*.{ts,mjs,cjs,vue,json,md,yml,yaml,scss,css,html}": "prettier --write"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.4.0",
    "@mdi/font": "^7.4.47",
    "@tauri-apps/api": "^2.11.1",
    "pinia": "^3.0.4",
    "vue-i18n": "^11.4.6",
    "vuetify": "^4.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.10.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-vuetify": "^2.7.2",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "sass": "^1.101.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.3",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "@parcel/watcher@2.5.6": true
  }
}
