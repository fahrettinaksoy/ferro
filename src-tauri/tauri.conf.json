{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ferro",
  "version": "0.1.0",
  "identifier": "com.ferro.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:vite"
  },
  "app": {
    "windows": [
      {
        "title": "Ferro",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; form-action 'self'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2026 Fahrettin Aksoy",
    "category": "DeveloperTool",
    "shortDescription": "Security-focused FTP/FTPS/SFTP client",
    "longDescription": "Ferro — a modern, security-focused FTP/FTPS/SFTP desktop client.",
    "resources": {
      "../seed/sites.seed.json": "seed/sites.seed.json"
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
