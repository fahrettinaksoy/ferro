{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Ferro ana pencere yetkileri (uygulama kendi Rust komutlarını kullanır; eklenti yüzeyi asgari tutulur).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-set-title",
    "core:webview:allow-create-webview-window"
  ]
}
