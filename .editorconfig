# EditorConfig — editörler arası tutarlı boşluk/kodlama.
# https://editorconfig.org  ·  Prettier (.prettierrc.yaml) ile hizalı.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Rust: rustfmt varsayılanı 4 boşluk.
[*.rs]
indent_size = 4

# Markdown: satır sonu boşlukları anlamlı olabilir (iki boşluk = <br>).
[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
